# =============================================================================
# Security-scan defaults — loaded from this file by scanner/cli.py at startup.
# CLI flags override these. Real OS environment variables override .env values.
# Lines starting with `#` are comments. Empty values = "use built-in default".
# =============================================================================

# --- Model & concurrency -----------------------------------------------------

# Two-slot model selection. The opencode provider config and credentials
# live in ~/.config/opencode/opencode.json — not here.

# Heavy model — handles all assessment work: project discovery (Phase 0),
# dependency audit (Phase 1), per-file review (Phase 2), and the
# confirmation pass. This is where scan accuracy comes from; use your
# highest-quality available model.
SCAN_MODEL_HEAVY=azure/gpt-5.5

# Light model — handles structural post-processing only: the per-file
# semantic dedup clustering and the final business summary. A smaller /
# cheaper model is fine here; quality impact on the actual findings is
# minimal because the heavy model has already produced and confirmed
# them by this point.
SCAN_MODEL_LIGHT=azure/gpt-5.4-mini

# Legacy single-model setting. If set and SCAN_MODEL_HEAVY or
# SCAN_MODEL_LIGHT above is empty, it fills the empty slot — so an
# existing `SCAN_MODEL=azure/gpt-5.5` line keeps running every phase
# on 5.5 until you opt into the split. Leave empty in new configs.
SCAN_MODEL=

# Maximum concurrent opencode calls. Each phase (per-file review, confirmation,
# dedup) parallelises independently up to this number. Drop to 5 if Azure
# returns 429s on smaller deployments.
SCAN_PARALLEL=4

# Per-call timeout in seconds. Discovery and dependency phases get 2x this.
SCAN_TIMEOUT=300

# Per-file size cap in bytes. Files larger than this are skipped (the model
# would truncate them anyway and findings get noisy).
SCAN_MAX_FILE_SIZE=125000

# --- File selection ----------------------------------------------------------

# Comma-separated source extensions to scan in the per-file phase. Leave
# empty to use the built-in list (.cs/.py/.js/.ts/.cpp/... see
# scanner/config.py:DEFAULT_EXTENSIONS). Manifests are always included
# regardless of this list.
SCAN_EXTENSIONS=

# Extra directory basenames to exclude, comma-separated. Merged with the
# built-in defaults (.git, node_modules, bin, obj, venv, dist, target, ...).
# Matched on basename only — no globs, no paths. Example: docs,migrations
SCAN_EXCLUDE_DIRS=

# --- Phase skips -------------------------------------------------------------
# Set to 1 / true / yes to skip a phase. Empty / 0 / false runs the phase.

# Phase 0 — project brief. Skip if you have a cached brief and want speed.
SCAN_SKIP_DISCOVERY=

# Phase 1 — dependency audit (manifests, EOL runtimes, known CVEs).
SCAN_SKIP_DEPENDENCIES=

# Confirmation pass — re-verifies each finding (`confirmed/likely/false_positive`).
# Skipping this leaves all findings as `likely` and disables severity overrides.
SCAN_SKIP_CONFIRMATION=

# Semantic dedup pass — per-file LLM clustering of duplicate findings.
SCAN_SKIP_DEDUP=

# Phase 1 osv-scanner ground-truth CVE injection. The Phase 1 prompt embeds
# osv-scanner output so the LLM has authoritative version-range matching
# against an offline OSV/GHSA snapshot; skipping this falls back to the
# model's training knowledge only.
SCAN_SKIP_SCA=

# --- Misc --------------------------------------------------------------------

# Project brief is scoped to a single run (in-memory) and not persisted.

# Directory of developer feedback .md files. Every .md (recursive, sorted)
# is concatenated and injected into the per-file, dependency, and
# confirmation prompts so the model treats their content as authoritative
# context (whitelist intentional findings, document accepted risks, point
# at non-obvious helpers). Empty = auto-resolve to <input-root>/feedback
# when scanning under input/sourcecode/<project>/. See
# input/feedback/README.md for the format and trust model.
SCAN_FEEDBACK_DIR=

# --- SCA (osv-scanner) -------------------------------------------------------

# Local OSV/GHSA database path. The Phase 1 prelude reads CVE matches from
# this directory. By default a missing or stale (>7 days) DB triggers an
# automatic refresh during the next scan (~1.5–2 GB on first run; subsequent
# refreshes are incremental and small). Set SCAN_NO_AUTO_REFRESH_OSV_DB=1
# below if you prefer to manage refreshes yourself via cron + the explicit
# `python security-scan.py --refresh-osv-db` command.
# Empty = .security-scan-cache/osv/ (next to security-scan.py).
SCAN_OSV_DB_DIR=

# Disable the auto-refresh-during-scan behaviour. Empty / 0 / false (default)
# = scan auto-refreshes a missing or stale DB before reading it, so Phase 1
# always has the most current ground truth. Set to 1 / true / yes for:
#   - cron-driven setups that already run --refresh-osv-db on a schedule
#     (no point doing it twice)
#   - air-gapped hosts where the auto-refresh would only fail and waste time
#   - CI pipelines that pre-populate the DB out-of-band and want
#     deterministic timing per scan
# A failed auto-refresh always falls through to the stamped-degrade
# contract — the scan still completes, the report just lacks SCA ground
# truth and is stamped with `reason: refresh_failed`.
SCAN_NO_AUTO_REFRESH_OSV_DB=

# Override the bundled osv-scanner binary. By default the scanner downloads
# the pinned osv-scanner release on first use (sha256-verified, cached at
# .security-scan-cache/bin/osv-scanner-v<pinned>). Set to a pre-installed
# binary path for air-gapped or corp-mirrored environments.
SCAN_OSV_SCANNER_BIN=
